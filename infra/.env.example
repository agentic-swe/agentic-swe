# Copy to infra/.env and set values (infra/.env is gitignored).
# Used by deploy-static-site.sh when present.

AWS_REGION=us-east-1
S3_STATIC_BUCKET=your-bucket-name
CLOUDFRONT_DISTRIBUTION_ID=YOUR_DISTRIBUTION_ID
# Optional: printed at end of deploy
# CLOUDFRONT_SITE_URL=https://xxxxxxxxxxxxxx.cloudfront.net
